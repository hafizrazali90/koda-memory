{
  "name": "koda-memory",
  "version": "0.1.0",
  "description": "Persistent, searchable memory MCP server for Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
